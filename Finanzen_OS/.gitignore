# --- Python & System ---
.venv/
__pycache__/
.idea/
.vscode/
*.py[cod]

# --- Excel Sperrdateien (WICHTIG!) ---
# Ignoriert die temporären Dateien, die Excel beim Öffnen erstellt
~$*
.~lock.*

# --- Private Finanzdaten (DATENSCHUTZ) ---
# Wir ignorieren alle CSVs in data/input und data/output
data/input/*.csv
data/output/*.csv
data/archiv/

# Falls du die processed_ids.txt hast:
data/processed_ids.txt

# --- Was wir BEHALTEN wollen ---
# Wir stellen sicher, dass die leeren Ordner oder .gitkeep Dateien
# hochgeladen werden, damit die Struktur auf GitHub sichtbar bleibt.
!data/input/.gitkeep
!data/output/.gitkeep
!data/rules/*.json